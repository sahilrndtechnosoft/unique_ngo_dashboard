generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model area_postal_codes {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  service_area_id String @db.Uuid
  postal_code     String   @db.VarChar(20)
  locality        String?  @db.VarChar(255)
  is_active       Boolean  @default(true)
  created_at      DateTime @default(now()) @db.Timestamptz(6)
  @@unique([service_area_id, postal_code], map: "area_postal_codes_unique")
  @@index([is_active])
  @@index([created_at])
}

model auth_sessions {
  id                     String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id                String    @db.Uuid
  refresh_token_hash     String    @unique
  device_id              String?   @db.VarChar(255)
  device_name            String?   @db.VarChar(255)
  device_type            String?   @db.VarChar(100)
  os                     String?   @db.VarChar(100)
  app_version            String?   @db.VarChar(50)
  ip_address             String?   @db.Inet
  user_agent             String?
  is_active              Boolean   @default(true)
  expires_at             DateTime  @db.Timestamptz(6)
  last_used_at           DateTime? @db.Timestamptz(6)
  revoked_at             DateTime? @db.Timestamptz(6)
  revoked_by_ip          String?   @db.Inet
  replaced_by_session_id String?   @db.Uuid
  revoke_reason          String?   @db.VarChar(100)
  created_at             DateTime  @default(now()) @db.Timestamptz(6)
  updated_at             DateTime  @default(now()) @db.Timestamptz(6)
  @@index([is_active])
  @@index([created_at])
  @@index([expires_at])
  @@index([user_id])
  @@index([user_id, is_active])
  @@index([replaced_by_session_id])
}

model blood_admin_notes {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  entity_type String   @db.VarChar(50)
  entity_id   String @db.Uuid
  admin_id    String @db.Uuid
  note        String
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  @@index([created_at])
  @@index([entity_id])
  @@index([admin_id])
  @@index([entity_type, entity_id])
}

model blood_compatibility {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  donor_group     blood_group
  recipient_group blood_group
  is_compatible   Boolean     @default(false)
  @@unique([donor_group, recipient_group], map: "blood_compatibility_unique")
}

model blood_donation_responses {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  blood_request_id String @db.Uuid
  donor_id         String @db.Uuid
  units_pledged    Decimal         @default(1) @db.Decimal(5, 2)
  status           donation_status @default(PENDING)
  response_note    String?
  donation_date    DateTime?       @db.Date
  donation_id      String? @db.Uuid
  admin_note       String?
  reviewed_by_id   String? @db.Uuid
  reviewed_at      DateTime?       @db.Timestamptz(6)
  created_at       DateTime        @default(now()) @db.Timestamptz(6)
  updated_at       DateTime        @default(now()) @db.Timestamptz(6)
  @@unique([blood_request_id, donor_id], map: "blood_donation_responses_unique")
  @@index([status])
  @@index([created_at])
  @@index([donation_id])
  @@index([reviewed_by_id])
}

model blood_donations {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  donor_id         String @db.Uuid
  blood_group      blood_group
  donation_date    DateTime        @db.Date
  donation_center  String?         @db.VarChar(255)
  hospital_name    String?         @db.VarChar(255)
  city             String?         @db.VarChar(100)
  state            String?         @db.VarChar(100)
  units_donated    Decimal         @default(1) @db.Decimal(5, 2)
  status           donation_status @default(PENDING)
  proof_image_url  String?
  notes            String?
  verified_by_id   String? @db.Uuid
  verified_at      DateTime?       @db.Timestamptz(6)
  rejection_reason String?
  certificate_url  String?
  is_camp_donation Boolean         @default(false)
  campaign_id      String? @db.Uuid
  reward_claimed   Boolean         @default(false)
  reward_claim_id  String? @db.Uuid
  created_at       DateTime        @default(now()) @db.Timestamptz(6)
  updated_at       DateTime        @default(now()) @db.Timestamptz(6)
  deleted_at       DateTime?       @db.Timestamptz(6)
  @@index([status])
  @@index([created_at])
  @@index([deleted_at])
  @@index([donor_id])
  @@index([verified_by_id])
  @@index([campaign_id])
  @@index([reward_claim_id])
}

model blood_donor_profiles {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id            String @db.Uuid      @unique
  blood_group        blood_group
  is_available       Boolean     @default(true)
  total_donations    Int         @default(0)
  last_donation_date DateTime?   @db.Date
  next_eligible_date DateTime?   @db.Date
  weight_kg          Decimal?    @db.Decimal(5, 2)
  height_cm          Decimal?    @db.Decimal(5, 2)
  medical_conditions String?
  currently_on_meds  Boolean     @default(false)
  preferred_city     String?     @db.VarChar(100)
  preferred_state    String?     @db.VarChar(100)
  notify_nearby      Boolean     @default(true)
  radius_km          Int         @default(10)
  created_at         DateTime    @default(now()) @db.Timestamptz(6)
  updated_at         DateTime    @default(now()) @db.Timestamptz(6)
  @@index([created_at])
}

model blood_requests {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  requester_id     String @db.Uuid
  patient_name     String               @db.VarChar(255)
  blood_group      blood_group
  units_required   Decimal              @default(1) @db.Decimal(5, 2)
  units_fulfilled  Decimal              @default(0) @db.Decimal(5, 2)
  urgency          urgency_level        @default(MEDIUM)
  hospital_name    String               @db.VarChar(255)
  hospital_address String
  city             String               @db.VarChar(100)
  state            String               @db.VarChar(100)
  contact_name     String               @db.VarChar(255)
  contact_mobile   String               @db.VarChar(20)
  required_by_date DateTime             @db.Timestamptz(6)
  status           blood_request_status @default(OPEN)
  notes            String?
  is_emergency     Boolean              @default(false)
  admin_note       String?
  verified_by_id   String? @db.Uuid
  expires_at       DateTime?            @db.Timestamptz(6)
  created_at       DateTime             @default(now()) @db.Timestamptz(6)
  updated_at       DateTime             @default(now()) @db.Timestamptz(6)
  deleted_at       DateTime?            @db.Timestamptz(6)
  @@index([urgency])
  @@index([status])
  @@index([created_at])
  @@index([deleted_at])
  @@index([requester_id])
  @@index([verified_by_id])
}

model cart_items {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cart_id      String @db.Uuid
  product_id   String @db.Uuid
  variant_id   String? @db.Uuid
  quantity     Int      @default(1)
  price_at_add Decimal  @db.Decimal(12, 2)
  created_at   DateTime @default(now()) @db.Timestamptz(6)
  updated_at   DateTime @default(now()) @db.Timestamptz(6)
  @@unique([cart_id, product_id, variant_id], map: "cart_items_unique")
  @@index([created_at])
}

model carts {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id         String? @db.Uuid  @unique
  session_id      String?  @db.VarChar(255)
  coupon_code     String?  @db.VarChar(100)
  discount_amount Decimal  @default(0) @db.Decimal(12, 2)
  created_at      DateTime @default(now()) @db.Timestamptz(6)
  updated_at      DateTime @default(now()) @db.Timestamptz(6)
  @@index([created_at])
}

model commission_settings {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  category_id    String? @db.Uuid
  seller_id      String? @db.Uuid
  rate           Decimal   @db.Decimal(5, 2)
  is_default     Boolean   @default(false)
  effective_from DateTime  @default(dbgenerated("CURRENT_DATE")) @db.Date
  effective_to   DateTime? @db.Date
  created_by_id  String @db.Uuid
  created_at     DateTime  @default(now()) @db.Timestamptz(6)
  updated_at     DateTime  @default(now()) @db.Timestamptz(6)
  @@index([created_at])
  @@index([category_id])
  @@index([seller_id])
  @@index([created_by_id])
}

model coupon_usages {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  coupon_id String @db.Uuid
  user_id   String @db.Uuid
  order_id  String? @db.Uuid
  discount  Decimal  @db.Decimal(12, 2)
  used_at   DateTime @default(now()) @db.Timestamptz(6)
  @@unique([coupon_id, user_id, order_id], map: "coupon_usages_unique")
}

model coupons {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code            String    @unique @db.VarChar(100)
  description     String?
  discount_type   String    @default("PERCENTAGE") @db.VarChar(20)
  discount_value  Decimal   @db.Decimal(10, 2)
  min_order_value Decimal   @default(0) @db.Decimal(12, 2)
  max_discount    Decimal?  @db.Decimal(12, 2)
  usage_limit     Int?
  used_count      Int       @default(0)
  per_user_limit  Int       @default(1)
  is_active       Boolean   @default(true)
  applicable_to   String    @default("ALL") @db.VarChar(50)
  starts_at       DateTime  @default(now()) @db.Timestamptz(6)
  expires_at      DateTime? @db.Timestamptz(6)
  created_by_id   String @db.Uuid
  created_at      DateTime  @default(now()) @db.Timestamptz(6)
  updated_at      DateTime  @default(now()) @db.Timestamptz(6)
  @@index([is_active])
  @@index([created_at])
  @@index([created_by_id])
}

model delivery_fees {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  service_area_id String @db.Uuid
  shipping_type   shipping_type @default(STANDARD)
  min_order_value Decimal       @default(0) @db.Decimal(12, 2)
  fee             Decimal       @default(0) @db.Decimal(10, 2)
  is_free_above   Decimal?      @db.Decimal(12, 2)
  estimated_days  Int           @default(3)
  is_active       Boolean       @default(true)
  created_at      DateTime      @default(now()) @db.Timestamptz(6)
  updated_at      DateTime      @default(now()) @db.Timestamptz(6)
  @@index([is_active])
  @@index([created_at])
  @@index([service_area_id])
}

model delivery_tracking_events {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shipment_id String @db.Uuid
  status      String   @db.VarChar(100)
  location    String?  @db.VarChar(255)
  description String?
  occurred_at DateTime @default(now()) @db.Timestamptz(6)
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  @@index([status])
  @@index([created_at])
  @@index([shipment_id])
}

model device_tokens {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String @db.Uuid
  token      String
  platform   String   @db.VarChar(50)
  device_id  String?  @db.VarChar(255)
  is_active  Boolean  @default(true)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @db.Timestamptz(6)
  @@unique([user_id, device_id, platform], map: "device_tokens_unique")
  @@index([is_active])
  @@index([created_at])
}

model donation_certificates {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  donation_id    String @db.Uuid   @unique
  donor_id       String @db.Uuid
  certificate_no String   @unique @db.VarChar(100)
  issued_at      DateTime @default(now()) @db.Timestamptz(6)
  file_url       String
  is_valid       Boolean  @default(true)
  created_at     DateTime @default(now()) @db.Timestamptz(6)
  @@index([created_at])
  @@index([donor_id])
}

model donation_item_images {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  donation_item_id String @db.Uuid
  url              String
  sort_order       Int      @default(0)
  is_primary       Boolean  @default(false)
  created_at       DateTime @default(now()) @db.Timestamptz(6)
  @@index([created_at])
  @@index([donation_item_id])
}

model donation_item_requests {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  donation_item_id String @db.Uuid
  requester_id     String @db.Uuid
  quantity_needed  Int             @default(1)
  purpose          String
  status           approval_status @default(PENDING)
  admin_note       String?
  reviewed_by_id   String? @db.Uuid
  reviewed_at      DateTime?       @db.Timestamptz(6)
  created_at       DateTime        @default(now()) @db.Timestamptz(6)
  updated_at       DateTime        @default(now()) @db.Timestamptz(6)
  @@index([status])
  @@index([created_at])
  @@index([donation_item_id])
  @@index([requester_id])
  @@index([reviewed_by_id])
}

model donation_items {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  donor_id       String @db.Uuid
  title          String                  @db.VarChar(500)
  description    String
  category_id    String? @db.Uuid
  condition      donation_item_condition @default(GOOD)
  quantity       Int                     @default(1)
  status         donation_item_status    @default(AVAILABLE)
  pickup_city    String                  @db.VarChar(100)
  pickup_state   String                  @db.VarChar(100)
  pickup_address String?
  is_pickup_only Boolean                 @default(true)
  admin_note     String?
  verified_by_id String? @db.Uuid
  verified_at    DateTime?               @db.Timestamptz(6)
  tags           String[]
  created_at     DateTime                @default(now()) @db.Timestamptz(6)
  updated_at     DateTime                @default(now()) @db.Timestamptz(6)
  deleted_at     DateTime?               @db.Timestamptz(6)
  @@index([status])
  @@index([created_at])
  @@index([deleted_at])
  @@index([donor_id])
  @@index([category_id])
  @@index([verified_by_id])
}

model donation_transfers {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  donation_item_id    String @db.Uuid
  request_id          String @db.Uuid
  donor_id            String @db.Uuid
  recipient_id        String @db.Uuid
  quantity            Int       @default(1)
  transfer_date       DateTime? @db.Date
  proof_image_url     String?
  donor_confirmed     Boolean   @default(false)
  recipient_confirmed Boolean   @default(false)
  admin_confirmed     Boolean   @default(false)
  notes               String?
  created_at          DateTime  @default(now()) @db.Timestamptz(6)
  updated_at          DateTime  @default(now()) @db.Timestamptz(6)
  @@index([created_at])
  @@index([donation_item_id])
  @@index([request_id])
  @@index([donor_id])
  @@index([recipient_id])
}

model emergency_contacts {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id       String @db.Uuid
  name          String   @db.VarChar(255)
  relation      String   @db.VarChar(100)
  mobile        String   @db.VarChar(20)
  email         String?  @db.VarChar(255)
  is_primary    Boolean  @default(false)
  notify_on_sos Boolean  @default(true)
  created_at    DateTime @default(now()) @db.Timestamptz(6)
  updated_at    DateTime @default(now()) @db.Timestamptz(6)
  @@index([created_at])
  @@index([user_id])
}

model equipment {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  category_id        String @db.Uuid
  owner_id           String? @db.Uuid
  name               String              @db.VarChar(255)
  slug               String              @unique @db.VarChar(255)
  description        String
  brand              String?             @db.VarChar(255)
  model              String?             @db.VarChar(255)
  serial_number      String?             @db.VarChar(255)
  condition          equipment_condition @default(GOOD)
  daily_rate         Decimal             @db.Decimal(10, 2)
  weekly_rate        Decimal?            @db.Decimal(10, 2)
  monthly_rate       Decimal?            @db.Decimal(10, 2)
  security_deposit   Decimal             @default(0) @db.Decimal(12, 2)
  min_rental_days    Int                 @default(1)
  max_rental_days    Int                 @default(90)
  total_quantity     Int                 @default(1)
  available_quantity Int                 @default(1)
  rented_quantity    Int                 @default(0)
  is_active          Boolean             @default(true)
  is_featured        Boolean             @default(false)
  requires_training  Boolean             @default(false)
  training_notes     String?
  service_area_id    String? @db.Uuid
  pickup_available   Boolean             @default(false)
  delivery_available Boolean             @default(true)
  weight_kg          Decimal?            @db.Decimal(8, 2)
  dimensions         Json?
  specifications     Json?
  admin_verified     Boolean             @default(false)
  verified_by_id     String? @db.Uuid
  verified_at        DateTime?           @db.Timestamptz(6)
  meta_title         String?             @db.VarChar(255)
  meta_description   String?
  created_at         DateTime            @default(now()) @db.Timestamptz(6)
  updated_at         DateTime            @default(now()) @db.Timestamptz(6)
  deleted_at         DateTime?           @db.Timestamptz(6)
  @@index([is_active])
  @@index([created_at])
  @@index([deleted_at])
  @@index([category_id])
  @@index([owner_id])
  @@index([service_area_id])
  @@index([verified_by_id])
}

model equipment_availability {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  equipment_id  String @db.Uuid
  date          DateTime @db.Date
  available_qty Int      @default(0)
  booked_qty    Int      @default(0)
  is_blocked    Boolean  @default(false)
  block_reason  String?
  @@unique([equipment_id, date], map: "equipment_availability_unique")
}

model equipment_categories {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
