  bank_account_no   String?       @db.VarChar(50)
  bank_ifsc         String?       @db.VarChar(20)
  bank_name         String?       @db.VarChar(255)
  bank_account_name String?       @db.VarChar(255)
  upi_id            String?       @db.VarChar(255)
  verified_by_id    String? @db.Uuid
  verified_at       DateTime?     @db.Timestamptz(6)
  rejection_reason  String?
  service_area_ids  String[] @db.Uuid
  created_at        DateTime      @default(now()) @db.Timestamptz(6)
  updated_at        DateTime      @default(now()) @db.Timestamptz(6)
  deleted_at        DateTime?     @db.Timestamptz(6)
  @@index([status])
  @@index([created_at])
  @@index([deleted_at])
  @@index([verified_by_id])
}

model service_areas {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String      @db.VarChar(255)
  city       String      @db.VarChar(100)
  state      String      @db.VarChar(100)
  country    String      @default("India") @db.VarChar(100)
  status     area_status @default(ACTIVE)
  base_lat   Decimal?    @db.Decimal(10, 8)
  base_lng   Decimal?    @db.Decimal(11, 8)
  radius_km  Decimal?    @db.Decimal(8, 2)
  created_at DateTime    @default(now()) @db.Timestamptz(6)
  updated_at DateTime    @default(now()) @db.Timestamptz(6)
  @@index([status])
  @@index([created_at])
}

model shipments {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  order_id        String @db.Uuid    @unique
  tracking_number String?   @db.VarChar(255)
  carrier         String?   @db.VarChar(255)
  tracking_url    String?
  status          String    @default("PENDING") @db.VarChar(100)
  shipped_at      DateTime? @db.Timestamptz(6)
  delivered_at    DateTime? @db.Timestamptz(6)
  estimated_date  DateTime? @db.Date
  notes           String?
  created_at      DateTime  @default(now()) @db.Timestamptz(6)
  updated_at      DateTime  @default(now()) @db.Timestamptz(6)
  @@index([status])
  @@index([created_at])
}

model user_addresses {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id       String @db.Uuid
  label         String?   @db.VarChar(100)
  full_name     String    @db.VarChar(255)
  mobile        String    @db.VarChar(20)
  address_line1 String
  address_line2 String?
  city          String    @db.VarChar(100)
  state         String    @db.VarChar(100)
  postal_code   String    @db.VarChar(20)
  country       String    @default("India") @db.VarChar(100)
  latitude      Decimal?  @db.Decimal(10, 8)
  longitude     Decimal?  @db.Decimal(11, 8)
  is_default    Boolean   @default(false)
  created_at    DateTime  @default(now()) @db.Timestamptz(6)
  updated_at    DateTime  @default(now()) @db.Timestamptz(6)
  deleted_at    DateTime? @db.Timestamptz(6)
  @@index([created_at])
  @@index([deleted_at])
  @@index([user_id])
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model users {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  role               user_role    @default(USER)
  status             user_status  @default(PENDING_VERIFICATION)
  full_name          String       @db.VarChar(255)
  email              String?      @unique(map: "users_email_unique") @db.VarChar(255)
  mobile             String?      @unique(map: "users_mobile_unique") @db.VarChar(20)
  mobile_verified    Boolean      @default(false)
  email_verified     Boolean      @default(false)
  password_hash      String?
  gender             gender?
  date_of_birth      DateTime?    @db.Date
  profile_image_url  String?
  blood_group        blood_group?
  bio                String?
  is_available_donor Boolean      @default(false)
  last_donation_date DateTime?    @db.Date
  referral_code      String?      @unique @db.VarChar(20)
  referred_by_id     String? @db.Uuid
  total_donations    Int          @default(0)
  total_points       Int          @default(0)
  created_at         DateTime     @default(now()) @db.Timestamptz(6)
  updated_at         DateTime     @default(now()) @db.Timestamptz(6)
  deleted_at         DateTime?    @db.Timestamptz(6)
  @@index([role])
  @@index([status])
  @@index([created_at])
  @@index([deleted_at])
  @@index([referred_by_id])
}

model wallet_accounts {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id        String @db.Uuid   @unique
  balance        Decimal  @default(0) @db.Decimal(12, 2)
  total_credited Decimal  @default(0) @db.Decimal(12, 2)
  total_debited  Decimal  @default(0) @db.Decimal(12, 2)
  is_active      Boolean  @default(true)
  created_at     DateTime @default(now()) @db.Timestamptz(6)
  updated_at     DateTime @default(now()) @db.Timestamptz(6)
  @@index([is_active])
  @@index([created_at])
}

model wallet_transactions {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  wallet_id      String @db.Uuid
  user_id        String @db.Uuid
  type           transaction_type
  amount         Decimal          @db.Decimal(12, 2)
  balance_after  Decimal          @db.Decimal(12, 2)
  reference_type String?          @db.VarChar(100)
  reference_id   String? @db.Uuid
  description    String
  payment_id     String? @db.Uuid
  created_at     DateTime         @default(now()) @db.Timestamptz(6)
  @@index([created_at])
  @@index([wallet_id])
  @@index([user_id])
  @@index([reference_id])
  @@index([payment_id])
  @@index([reference_type, reference_id])
}

model wishlists {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String @db.Uuid
  product_id String @db.Uuid
  variant_id String? @db.Uuid
  created_at DateTime @default(now()) @db.Timestamptz(6)
  @@unique([user_id, product_id], map: "wishlists_unique")
  @@index([created_at])
  @@index([variant_id])
}

