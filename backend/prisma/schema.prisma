  updated_at  DateTime @default(now()) @db.Timestamptz(6)
  @@index([is_active])
  @@index([created_at])
  @@index([parent_id])
}

model equipment_images {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  equipment_id String @db.Uuid
  url          String
  alt_text     String?  @db.VarChar(255)
  sort_order   Int      @default(0)
  is_primary   Boolean  @default(false)
  created_at   DateTime @default(now()) @db.Timestamptz(6)
  @@index([created_at])
  @@index([equipment_id])
}

model equipment_maintenance {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  equipment_id     String @db.Uuid
  maintenance_type String    @db.VarChar(100)
  description      String
  performed_by     String?   @db.VarChar(255)
  performed_at     DateTime  @db.Timestamptz(6)
  cost             Decimal?  @db.Decimal(10, 2)
  next_due_date    DateTime? @db.Date
