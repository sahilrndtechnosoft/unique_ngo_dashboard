}

model membership_history {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id         String @db.Uuid
  subscription_id String @db.Uuid
  plan_id         String @db.Uuid
  action          String   @db.VarChar(100)
  performed_by_id String? @db.Uuid
  note            String?
  created_at      DateTime @default(now()) @db.Timestamptz(6)
  @@index([created_at])
  @@index([user_id])
  @@index([subscription_id])
  @@index([plan_id])
  @@index([performed_by_id])
}

model membership_plans {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name              String        @db.VarChar(255)
  slug              String        @unique @db.VarChar(255)
  description       String?
  price             Decimal       @db.Decimal(10, 2)
  billing_cycle     billing_cycle @default(MONTHLY)
  duration_days     Int
  role              user_role     @default(PREMIUM_USER)
  features          Json          @default("[]")
  max_products      Int?
  commission_rate   Decimal?      @db.Decimal(5, 2)
  reward_multiplier Decimal       @default(1.0) @db.Decimal(5, 2)
