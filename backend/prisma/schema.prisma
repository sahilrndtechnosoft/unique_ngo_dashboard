}

model invoices {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  invoice_number  String   @unique @db.VarChar(100)
  payment_id      String @db.Uuid
  user_id         String @db.Uuid
  billing_name    String   @db.VarChar(255)
