DATABASE_URL=postgresql://user:password@localhost:5432/unique_ngo
PORT=3000
NODE_ENV=development

JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

BCRYPT_ROUNDS=12
OTP_EXPIRY_MINUTES=5
# Return OTP in send-otp response (auto-enabled when NODE_ENV !== production)
EXPOSE_OTP_IN_RESPONSE=true

APP_URL=http://localhost:3000
UPLOAD_DIR=uploads

# Admin seeder (npm run prisma:seed)
ADMIN_EMAIL=admin@unique-ngo.com
ADMIN_PASSWORD=Admin@123456
ADMIN_FULL_NAME=Super Admin
ADMIN_MOBILE=9999999999
ADMIN_ROLE=SUPER_ADMIN
